{
  "expo": {
    "name": "lumo-mobile",
    "slug": "lumo-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lumomobile",
    "userInterfaceStyle": "automatic",
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "jsEngine": "hermes"
    }
  }
}
