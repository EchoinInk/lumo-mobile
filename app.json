{
  "expo": {
    "name": "lumo-mobile",
    "slug": "lumo-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lumomobile",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "output": "static"
    }
  }
}
